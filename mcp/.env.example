# MCP Configuration for Kai AI Agent

# Server settings
MCP_PORT=3000
MCP_HOST=localhost

# thirdweb configuration
THIRDWEB_SECRET_KEY=
THIRDWEB_CLIENT_ID=
THIRDWEB_CHAIN_ID=1

# Agent-To-Agent Protocol
AGENT_ID=kai-ai-agent
AGENT_REGISTRY_URL=https://agents.openclaw.ai
AGENT_SIGNING_KEY=

# x402 Payment Protocol
X402_ENABLED=true
X402_PAYMENT_RECEIVER=0xf54961B4a97906cfc97007cDffdD2B521da0A4b6
X402_MIN_PAYMENT_USD=0.01
X402_SUPPORTED_TOKENS=USDC,USDT,DAI

# Wallet encryption
KAI_WALLET_KEY=KaiSecureVault_2025#Ocean

# Logging
LOG_LEVEL=info